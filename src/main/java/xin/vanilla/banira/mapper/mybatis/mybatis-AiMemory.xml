<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="xin.vanilla.banira.mapper.IAiMemoryDao">

    <resultMap id="resultMap" type="xin.vanilla.banira.domain.AiMemory">
        <id property="id" column="id"/>
        <result property="botId" column="bot_id"/>
        <result property="groupId" column="group_id"/>
        <result property="userId" column="user_id"/>
        <result property="content" column="content"/>
        <result property="tags" column="tags"/>
        <result property="sourceMsgId" column="source_msg_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="lastUsedAt" column="last_used_at"/>
    </resultMap>

    <sql id="allColumn">
        t.id, t.bot_id, t.group_id, t.user_id, t.content, t.tags, t.source_msg_id, t.created_at, t.last_used_at
    </sql>

    <sql id="whereSql">
        <trim prefix="WHERE" prefixOverrides="AND | OR ">
            <include refid="whereSqlInner"/>
        </trim>
    </sql>

    <sql id="whereSqlInner">
        <if test="bot_id != null">
            AND t.bot_id = #{bot_id}
        </if>
        <if test="group_id != null">
            AND t.group_id = #{group_id}
        </if>
        <if test="group_id_in_global != null">
            AND (t.group_id = #{group_id_in_global} OR t.group_id = 0)
        </if>
        <if test="user_id != null">
            AND t.user_id = #{user_id}
        </if>
        <if test="user_id_in_global != null">
            AND (t.user_id = #{user_id_in_global} OR t.user_id = 0)
        </if>
        <if test="content_like != null">
            AND t.content LIKE '%' || #{content_like} || '%'
        </if>
        <if test="tags_like != null">
            AND t.tags LIKE '%' || #{tags_like} || '%'
        </if>
    </sql>

    <sql id="orderSql">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <if test="_ORDER_ != null">
                <foreach collection="_ORDER_" item="item" open="" separator="," close="">
                    <include refid="orderSqlInner"/>
                </foreach>
            </if>
        </trim>
    </sql>

    <sql id="orderSqlInner">
        <if test="item == 'lastUsedAt_asc'">t.last_used_at ASC</if>
        <if test="item == 'lastUsedAt_desc'">t.last_used_at DESC</if>
        <if test="item == 'createdAt_asc'">t.created_at ASC</if>
        <if test="item == 'createdAt_desc'">t.created_at DESC</if>
        <if test="item == 'id_asc'">t.id ASC</if>
        <if test="item == 'id_desc'">t.id DESC</if>
    </sql>

    <sql id="limitSql">
        <if test="_LIMIT_ != null">
            LIMIT #{_LIMIT_}
        </if>
        <if test="_OFFSET_ != null">
            OFFSET #{_OFFSET_}
        </if>
    </sql>

    <select id="selectByParam" resultMap="resultMap">
        SELECT
        <include refid="allColumn"/>
        FROM ai_memory t
        <include refid="whereSql"/>
        <include refid="orderSql"/>
        <include refid="limitSql"/>
    </select>

    <select id="selectCountByParam" resultType="int">
        SELECT COUNT(1)
        FROM ai_memory t
        <include refid="whereSql"/>
    </select>

    <update id="updateLastUsedAt">
        UPDATE ai_memory
        SET last_used_at = #{lastUsedAt}
        WHERE id = #{id}
    </update>

</mapper>
