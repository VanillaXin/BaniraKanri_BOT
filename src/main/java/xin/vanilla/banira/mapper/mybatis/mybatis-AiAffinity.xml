<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="xin.vanilla.banira.mapper.IAiAffinityDao">

    <resultMap id="resultMap" type="xin.vanilla.banira.domain.AiAffinity">
        <id property="id" column="id"/>
        <result property="botId" column="bot_id"/>
        <result property="groupId" column="group_id"/>
        <result property="userId" column="user_id"/>
        <result property="score" column="score"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="allColumn">
        t.id, t.bot_id, t.group_id, t.user_id, t.score, t.updated_at
    </sql>

    <sql id="whereSql">
        <trim prefix="WHERE" prefixOverrides="AND | OR ">
            <if test="botId != null">
                AND t.bot_id = #{botId}
            </if>
            <if test="groupId != null">
                AND t.group_id = #{groupId}
            </if>
            <if test="userId != null">
                AND t.user_id = #{userId}
            </if>
        </trim>
    </sql>

    <sql id="limitSql">
        <if test="_LIMIT_ != null">
            LIMIT #{_LIMIT_}
        </if>
    </sql>

    <select id="selectByParam" resultMap="resultMap">
        SELECT
        <include refid="allColumn"/>
        FROM ai_affinity t
        <include refid="whereSql"/>
        ORDER BY t.id DESC
        <include refid="limitSql"/>
    </select>

    <update id="updateScore">
        UPDATE ai_affinity
        SET score = #{score}, updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <select id="upsertAndReturnScore" resultType="java.lang.Integer">
        INSERT INTO ai_affinity (bot_id, group_id, user_id, score, updated_at)
        VALUES (#{botId},
                #{groupId},
                #{userId},
                MIN(#{maxScore}, MAX(#{minScore}, #{initialScore} + #{delta})),
                #{updatedAt})
        ON CONFLICT (bot_id, group_id, user_id) DO UPDATE SET
            score = MIN(#{maxScore}, MAX(#{minScore}, score + #{delta})),
            updated_at = #{updatedAt}
        RETURNING score
    </select>

</mapper>
